---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getCategories } from "../../lib/wordpress";

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const categoryId = Astro.url.searchParams.get("category");

const [posts, categories] = await Promise.all([
    getCollection("posts", { page, perPage: 10, categories: categoryId }),
    getCategories(),
]);

const seoTitle = categoryId 
    ? `Blog - ${categories.find((c: any) => c.id == categoryId)?.name || 'Categoría'}`
    : "Blog - Listado de artículos";
const seoDesc = "Explora nuestros últimos artículos sobre WordPress y Astro.js";
---

<Layout title={seoTitle} description={seoDesc}>
    <nav>
        <a href="/blog">Todos</a>
        {
            categories.map((cat: any, index: number) => (
                <a href={`/blog?category=${cat.id}`}>{cat.name}</a>
            ))
        }
    </nav>

    <ul>
        {
            posts.map((post: any, index: number) => {
                const image = post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
                return (
                    <li>
                        {image && <img src={image} alt={post.title.rendered} />}
                        <a href={`/blog/${post.slug}`} set:html={post.title.rendered} />
                        <div set:html={post.excerpt.rendered} />
                    </li>
                );
            })
        }
    </ul>

    <nav>
        {page > 1 && <a href={`/blog?page=${page - 1}`}>Anterior</a>}
        <a href={`/blog?page=${page + 1}`}>Siguiente</a>
    </nav>
</Layout>
