---
import Layout from "../../layouts/Layout.astro";
import { getSingleBySlug, getAllForPaths } from "../../lib/wordpress";

export async function getStaticPaths() {
    const posts = await getAllForPaths("posts");
    return posts.map((p: any, index: number) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getSingleBySlug("posts", slug);
if (!post) return Astro.redirect("/404");

const image = post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
const seoTitle = post.title.rendered;
const seoDesc = post.excerpt.rendered;
---

<Layout 
    title={seoTitle} 
    description={seoDesc} 
    image={image}
    type="article"
>
    <article>
        <h1 set:html={post.title.rendered} />
        {image && <img src={image} alt={post.title.rendered} />}
        <div set:html={post.content.rendered} />
    </article>
</Layout>
